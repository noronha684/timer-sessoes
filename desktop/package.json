{
  "name": "timer-sessoes-desktop",
  "productName": "Timer de Sessões",
  "description": "Timer de Sessões para Windows — bandeja, atalho global e modo mini sobre timer.gnoronha.app",
  "version": "1.0.8",
  "private": true,
  "author": "Gabriel Noronha",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "icon": "node make-icon.js",
    "dist": "node make-icon.js && electron-builder --win nsis",
    "dist:store": "node make-icon.js && node make-appx-assets.js && electron-builder --win appx --x64"
  },
  "build": {
    "appId": "app.gnoronha.timer",
    "productName": "Timer de Sessões",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "float-preload.js",
      "float.html",
      "icon.png"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Timer de Sessões"
    },
    "appx": {
      "applicationId": "TimerSessoes",
      "identityName": "XPAsset.productivyislife",
      "publisher": "CN=7D2A6A52-0E8D-4771-AFE4-424AB6A0597F",
      "publisherDisplayName": "GabrielNoronha",
      "displayName": "Timer de Sessões",
      "languages": [
        "pt-BR"
      ],
      "backgroundColor": "#141416",
      "showNameOnTiles": true,
      "artifactName": "Timer-de-Sessoes-${version}-${arch}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "png-to-ico": "^3.0.2"
  }
}
